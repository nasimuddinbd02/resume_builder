generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Models ────────────────────────────────────

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  name           String?
  hashedPassword String?
  image          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  resumes        Resume[]
  accounts       Account[]
  sessions       Session[]
  
  // Stripe Subscription
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  aiCredits               Int       @default(5)
  resumesCreated          Int       @default(0)
  creditsUsed             Int       @default(0)
  jobApplications JobApplication[]
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Resume Domain ──────────────────────────────────────

model Resume {
  id       String  @id @default(uuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title    String
  isBase   Boolean @default(true)
  template String  @default("modern")

  // Personal details
  fullName String
  email    String
  phone    String?
  location String?
  website  String?
  linkedin String?
  github   String?
  summary  String?

  // Relations
  experiences WorkExperience[]
  education   Education[]
  skills      Skill[]
  projects    Project[]
  tailoring   TailoringJob? @relation("TailoredResume")

  jobApplications JobApplication[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WorkExperience {
  id           String  @id @default(uuid())
  resumeId     String
  resume       Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  jobTitle     String
  company      String
  location     String?
  startDate    String
  endDate      String?
  isCurrent    Boolean @default(false)
  achievements String  // JSON array stored as string for SQLite compatibility
  sortOrder    Int     @default(0)
}

model Education {
  id        String  @id @default(uuid())
  resumeId  String
  resume    Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  school    String
  degree    String
  field     String?
  location  String?
  startDate String?
  endDate   String
  gpa       String?
  sortOrder Int     @default(0)
}

model Skill {
  id       String  @id @default(uuid())
  resumeId String
  resume   Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  name     String
  category String?
}

model Project {
  id           String  @id @default(uuid())
  resumeId     String
  resume       Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  name         String
  description  String
  technologies String  // JSON array stored as string for SQLite compatibility
  link         String?
  sortOrder    Int     @default(0)
}

model TailoringJob {
  id              String  @id @default(uuid())
  jobTitle        String
  companyName     String
  jobDescription  String
  atsScore        Int?
  coverLetterText String?
  keywordsMatched String?

  tailoredResumeId String @unique
  tailoredResume   Resume @relation("TailoredResume", fields: [tailoredResumeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

model JobApplication {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeId    String?   // optional link to a resume used for this application
  resume      Resume?  @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  title       String
  company     String
  link        String?
  appliedAt   DateTime @default(now())
  status      String   @default("Applied")
  notes       String?
}
